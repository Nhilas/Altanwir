%%{init: {'themeVariables':{'fontSize':'18px'}, 'flowchart':{'curve':'basis', 'nodeSpacing':40, 'rankSpacing':60, 'subGraphTitleMargin':{'top':12,'bottom':12}}}}%%
flowchart TB

  subgraph SRC["<span style='font-size:28px;font-weight:700;color:#000'>Sources</span>"]
    direction LR
    SteamAPI(("Steam<br/>Storefront API"))
    IGDBAPI(("IGDB API"))
  end

  subgraph LAND["<span style='font-size:28px;font-weight:700;color:#000'>Landing zone: OneLake</span>"]
    direction LR
    NB_API[["NB_Steam_Reviews"]]
    LZ[/"/Files/Steam/Reviews/<br/>{run_id}/{execution_id}/<br/>batch_N.json"/]
  end

  subgraph BRZ["<span style='font-size:28px;font-weight:700;color:#000'>Bronze: schema-resilient ingest</span>"]
    direction LR
    NB_BRZ[["NB_Steam_Reviews_Bronze"]]
    NB_IGDB_B[["NB_1_Bronze"]]
    BSR[("bronze.steamReviews")]
    BG[("bronze.games")]
    BGTP[("bronze.{genres, themes, platforms, platform_types}")]
    BEX[("bronze.{external_games, external_game_sources}")]
  end

  subgraph SLV["<span style='font-size:28px;font-weight:700;color:#000'>Silver: surrogates, clean, enrich</span>"]
    direction LR
    NB_SLV[["NB_Steam_Reviews_Silver"]]
    NB_IGDB_S[["NB_2_Silver"]]
    SSR[("silver.steamReviews")]
    SG[("silver.games")]
    SGTP[("silver.{genres, themes, platforms}")]
    SBR[("silver.bridgeGame*")]
    SEX[("silver.externalGames")]
  end

  subgraph GLD["<span style='font-size:28px;font-weight:700;color:#000'>Gold: derive, aggregate</span>"]
    direction LR
    NB_GR[["NB_Steam_Reviews_Gold"]]
    NB_GS[["NB_Game_Scores_Gold<br/>━━━━━━━━━<br/>+ gold.factReviews<br/>+ silver.games (IGDB)"]]
    GFR[("gold.factReviews")]
    GFGS[("gold.factGameScores")]
  end

  subgraph VWS["<span style='font-size:28px;font-weight:700;color:#000'>Views: serving</span>"]
    direction LR
    VFR[("vw_factReviews")]
    VFGS[("vw_factGameScores")]
    VDIM[("vw_dim* · vw_gameCatalogue")]
    VAGG[("vw_agg*")]
  end

  %% Audit warehouse — control plane (floating, off-axis)
  LRV[("loadReviews (view)<br/>━━━━━━━━━<br/>serves cursor + watermark")]
  LCR[("loadControlReviews")]
  VC[("versionControl")]

  SteamAPI ==>|"pl_Steam_API · hourly"| NB_API
  NB_API   ==> LZ

  LZ      ==>|"pl_Steam_Medallion · daily incremental"| NB_BRZ
  NB_BRZ  ==> BSR
  BSR     ==> NB_SLV
  NB_SLV  ==> SSR
  SSR     ==> NB_GR
  NB_GR   ==> GFR
  NB_GS   ==> GFGS

  IGDBAPI   ==>|"pl_IGDB_Medallion"| NB_IGDB_B
  NB_IGDB_B ==> BG
  NB_IGDB_B ==> BGTP
  NB_IGDB_B ==> BEX
  BG        --> NB_IGDB_S
  BGTP      --> NB_IGDB_S
  BEX       --> NB_IGDB_S
  NB_IGDB_S ==> SG
  NB_IGDB_S ==> SGTP
  NB_IGDB_S ==> SBR
  NB_IGDB_S ==> SEX

  GFR  --> VFR
  GFGS --> VFGS
  SG   --> VDIM
  SGTP --> VDIM
  GFGS --> VAGG

  LCR    --- LRV
  LRV    -.->|"top-N + cursor"| NB_API
  NB_API -.->|"writes execution<br/>(is_loaded = 0)"| LCR
  LCR    -.->|"polls is_loaded = 0,<br/>sets to 1"| NB_BRZ
  VC     -.->|"source delta version"| NB_SLV
  VC     -.->|"source delta version"| NB_GR
  VC     -.->|"source delta version"| NB_GS


  LRV ~~~ NB_IGDB_B
  LRV ~~~ LCR
  LCR ~~~ BRZ
  SSR ~~~ VC
  VC ~~~ NB_GS
  SGTP ~~~ NB_GS

  %% Pipeline color coding — rose=Steam, violet=IGDB, slate=views + control plane
  linkStyle 0,1,3,4,5,6,7,8 stroke:#f43f5eaa,stroke-width:4.5px,color:#3b0d12
  linkStyle 9,10,11,12,13,14,16,17,18,19 stroke:#7c3aedaa,stroke-width:4.5px,color:#4c1d95
  linkStyle 20,21,22,23,24 stroke:#64748b,stroke-width:2px,color:#1c1917

  %% Title-clearance overrides: lower alpha on edges that intersect subgraph titles
  linkStyle 2 stroke:#f43f5e55,stroke-width:4.5px,color:#3b0d12
  linkStyle 15 stroke:#7c3aed55,stroke-width:4.5px,color:#4c1d95

  %% Audit control plane + VC connections — deepened for dark-mode visibility against silver subgraph
  linkStyle 25,26,27,28,29,30 stroke:#334155,stroke-width:2.5px,color:#1c1917

  %% Node fills — saturated mid-tone, readable on white AND dark backgrounds
  classDef source     fill:#93c5fd,stroke:#1e3a8a,stroke-width:2px,color:#000
  classDef landingFile fill:#fdba74,stroke:#9a3412,stroke-width:2px,color:#000
  classDef bronzeT    fill:#fdba74,stroke:#9a3412,stroke-width:2px,color:#000
  classDef silverT    fill:#cbd5e1,stroke:#334155,stroke-width:2px,color:#000
  classDef goldT      fill:#fbbf24,stroke:#854d0e,stroke-width:2px,color:#000
  classDef viewT      fill:#5eead4,stroke:#0f766e,stroke-width:2px,color:#000
  classDef notebook   fill:#fda4af,stroke:#9f1239,stroke-width:2.5px,color:#000
  classDef audit      fill:#a7f3d0,stroke:#064e3b,stroke-width:2px,color:#000

  class SteamAPI,IGDBAPI source
  class LZ landingFile
  class BSR,BG,BGTP,BEX bronzeT
  class SSR,SG,SGTP,SBR,SEX silverT
  class GFR,GFGS goldT
  class VFR,VFGS,VDIM,VAGG viewT
  class NB_API,NB_BRZ,NB_SLV,NB_GR,NB_GS,NB_IGDB_B,NB_IGDB_S notebook
  class LRV,LCR,VC audit

  %% Subgraph fills — 50% opacity of the node color
  style SRC  fill:#93c5fd80,stroke:#1e3a8a,stroke-width:2px
  style LAND fill:#fdba7480,stroke:#9a3412,stroke-width:2px
  style BRZ  fill:#fdba7480,stroke:#9a3412,stroke-width:2px
  style SLV  fill:#cbd5e180,stroke:#334155,stroke-width:2px
  style GLD  fill:#fbbf2480,stroke:#854d0e,stroke-width:2px
  style VWS  fill:#5eead480,stroke:#0f766e,stroke-width:2px
