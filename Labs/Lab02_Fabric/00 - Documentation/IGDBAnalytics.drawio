                <mxCell id="7" value="&lt;ul&gt;&lt;li&gt;&lt;font color=&quot;#484848&quot;&gt;id&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font color=&quot;#484848&quot;&gt;name&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font color=&quot;#484848&quot;&gt;alternative_names - array of alternative names&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font color=&quot;#484848&quot;&gt;genres - array of genre ids&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font color=&quot;#484848&quot;&gt;theme - array of theme ids&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font color=&quot;#484848&quot;&gt;platforms - array of platform ids&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font color=&quot;#484848&quot;&gt;first_release_date&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font color=&quot;#484848&quot;&gt;game_status - id of game status&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font color=&quot;#484848&quot;&gt;involved_companies - array of involved company Ids&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font color=&quot;#484848&quot;&gt;expansions - array of game Ids&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font color=&quot;#484848&quot;&gt;standalone_expansions - array of game ids&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font color=&quot;#484848&quot;&gt;remakes - array of game ids&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font color=&quot;#484848&quot;&gt;remasters - array of game ids&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font color=&quot;#484848&quot;&gt;version_parent - id of game (if a version, this is the main game)&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font color=&quot;#484848&quot;&gt;version_title&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;game_modes - array of game mode ids&lt;/span&gt;&lt;/li&gt;&lt;li style=&quot;color: rgb(192, 192, 192); scrollbar-color: rgb(75, 75, 75) rgb(27, 29, 30);&quot;&gt;&lt;font style=&quot;scrollbar-color: rgb(75, 75, 75) rgb(27, 29, 30);&quot;&gt;storyline&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;color: rgb(192, 192, 192); scrollbar-color: rgb(75, 75, 75) rgb